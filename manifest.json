{
  "manifest_version": 3,
  "name": "⚡Turbo Flow",
  "version": "2.4",
  "icons": {
    "16": "logo16.png",
    "32": "logo32.png",
    "48": "logo48.png",
    "128": "logo128.png"
  },
  "permissions": [
    "webRequest",
    "tabs",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://make.powerautomate.com/*",
    "https://api.flow.microsoft.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "⚡Turbo Flow",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "logo16.png",
      "32": "logo32.png",
      "48": "logo48.png",
      "128": "logo128.png"
    }
  }
}